{
  "name": "k1w1-a0style",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:silent": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "vitest run --reporter verbose",
    "test:unit": "vitest run --dir __tests__",
    "test:integration": "vitest run --dir __tests__",
    "test:clear": "vitest --clearScreen=false",
    "postinstall": "patch-package",
    "preflight": "npm run lint:ci && npm run typecheck && npm run test:silent && npx expo-doctor",
    "eas-prebuild": "npm run preflight",
    "prepare": "husky",
    "k1w1:sync-native": "node scripts/k1w1-sync-native.mjs --apply",
    "k1w1:sync-native:report": "node scripts/k1w1-sync-native.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~51.0.28",
    "expo-application": "~5.9.1",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.2",
    "expo-device": "~6.0.2",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.23",
    "expo-splash-screen": "~0.27.6",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-webview": "13.8.6"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.7.0",
    "@types/node": "^20.14.12",
    "@types/react": "~18.2.79",
    "@types/react-test-renderer": "18.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-universe": "^14.2.0",
    "husky": "^9.0.11",
    "patch-package": "^8.0.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.5"
  }
}
