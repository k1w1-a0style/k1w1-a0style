  {
    "path": "package.json",
    "content": "{\n  \"name\": \"k1w1-app\",\n  \"version\": \"1.0.0\",\n  \"private\": true,\n  \"main\": \"node_modules/expo/AppEntry.js\",\n  \"scripts\": {\n    \"start\": \"expo start\",\n    \"android\": \"expo start --android\",\n    \"ios\": \"expo start --ios\",\n    \"web\": \"expo start --web\"\n  },\n  \"dependencies\": {\n    \"expo\": \"~54.0.0\",\n    \"react\": \"18.3.1\",\n    \"react-native\": \"0.76.5\"\n  },\n  \"devDependencies\": {\n    \"@babel/core\": \"^7.25.2\",\n    \"@types/react\": \"~18.3.12\",\n    \"typescript\": \"^5.3.3\"\n  }\n}"
  },
  {
    "path": "app.json",
    "content": "{\n  \"expo\": {\n    \"name\": \"K1w1-App\",\n    \"slug\": \"k1w1-app\",\n    \"owner\": \"a0style\",\n    \"version\": \"1.0.0\",\n    \"orientation\": \"portrait\",\n    \"userInterfaceStyle\": \"dark\",\n    \"ios\": { \"supportsTablet\": true, \"bundleIdentifier\": \"de.k1w1.app\" },\n    \"android\": { \"package\": \"de.k1w1.app\" },\n    \"web\": { \"bundler\": \"metro\", \"output\": \"static\" },\n    \"plugins\": [],\n    \"experiments\": { \"typedRoutes\": false },\n    \"extra\": { \"eas\": { \"projectId\": \"{PROJECT_ID}\" } },\n    \"react-native\": { \"android\": { \"packageName\": \"de.k1w1.app\" } }\n  }\n}"
  },
  {
    "path": "eas.json",
    "content": "{\n  \"build\": {\n    \"production\": {\n      \"android\": { \"buildType\": \"apk\" }\n    }\n  }\n}\n"
  },
  {
    "path": \".github/workflows/deploy-supabase-functions.yml\",
    \"content\": \"name: Deploy Supabase Functions & EAS Build\\n\\non:\\n  workflow_dispatch:\\n    inputs:\\n      job_id:\\n        description: 'Build Job ID from Supabase'\\n        required: true\\n        type: string\\n\\njobs:\\n  deploy-and-build:\\n    runs-on: ubuntu-latest\\n\\n    env:\\n      SUPABASE_URL: ${{ secrets.SUPABASE_URL }}\\n      SUPABASE_SERVICE_ROLE_KEY: ${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}\\n      EXPO_PROJECT_ID: ${{ secrets.EXPO_PROJECT_ID }}\\n      JOB_ID: ${{ github.event.inputs.job_id }}\\n\\n    steps:\\n      - name: Checkout\\n        uses: actions/checkout@v4\\n\\n      - name: Setup Node (v20)\\n        uses: actions/setup-node@v4\\n        with:\\n          node-version: 20\\n\\n      - name: Setup Expo & EAS\\n        uses: expo/expo-github-action@v8\\n        with:\\n          expo-version: latest\\n          eas-version: latest\\n          token: ${{ secrets.EXPO_TOKEN }}\\n          packager: npm\\n\\n      - name: Check EAS Auth\\n        run: eas whoami\\n\\n      - name: Inject projectId into app.json (if placeholder)\\n        run: |\\n          set -e\\n          if [ -z \\\"$EXPO_PROJECT_ID\\\" ]; then\\n            echo '::error::EXPO_PROJECT_ID secret fehlt.'; exit 1;\\n          fi\\n          if grep -q '{PROJECT_ID}' app.json; then\\n            sed -i \\\"s/{PROJECT_ID}/$EXPO_PROJECT_ID/g\\\" app.json\\n            echo 'projectId eingesetzt.'\\n          else\\n            echo 'projectId bereits gesetzt.'\\n          fi\\n          cat app.json\\n\\n      - name: Install dependencies\\n        run: npm install\\n\\n      - name: Update Build Status - Building\\n        run: |\\n          if [ -z \\\"$SUPABASE_URL\\\" ] || [ -z \\\"$SUPABASE_SERVICE_ROLE_KEY\\\" ]; then\\n            echo \\\"::error::SUPABASE_URL oder SUPABASE_SERVICE_ROLE_KEY nicht gesetzt.\\\"\\n            exit 1\\n          fi\\n\\n          curl -sS -X PATCH \\\"${SUPABASE_URL}/rest/v1/build_jobs?id=eq.${JOB_ID}\\\" \\\\\\n            -H \\\"apikey: ${SUPABASE_SERVICE_ROLE_KEY}\\\" \\\\\\n            -H \\\"Authorization: Bearer ${SUPABASE_SERVICE_ROLE_KEY}\\\" \\\\\\n            -H \\\"Content-Type: application/json\\\" \\\\\\n            -d \\\"{\\\\\\\"status\\\\\\\":\\\\\\\"building\\\\\\\",\\\\\\\"github_run_id\\\\\\\":\\\\\\\"${{ github.run_id }}\\\\\\\"}\\\"\\n\\n      - name: Run EAS Build (Android, no-wait)\\n        id: eas\\n        run: |\\n          set -e\\n          BUILD_OUTPUT=$(eas build --platform android --profile production --non-interactive --no-wait 2>&1)\\n          echo \\\"$BUILD_OUTPUT\\\"\\n          BUILD_ID=$(echo \\\"$BUILD_OUTPUT\\\" | grep -oP 'Build ID: \\\\K[a-f0-9-]+' || echo \\\"unknown\\\")\\n          echo \\\"Build ID detected: $BUILD_ID\\\"\\n          echo \\\"build_id=$BUILD_ID\\\" >> $GITHUB_OUTPUT\\n\\n      - name: Update Build Status - Success\\n        if: success()\\n        run: |\\n          curl -sS -X PATCH \\\"${SUPABASE_URL}/rest/v1/build_jobs?id=eq.${JOB_ID}\\\" \\\\\\n            -H \\\"apikey: ${SUPABASE_SERVICE_ROLE_KEY}\\\" \\\\\\n            -H \\\"Authorization: Bearer ${SUPABASE_SERVICE_ROLE_KEY}\\\" \\\\\\n            -H \\\"Content-Type: application/json\\\" \\\\\\n            -d \\\"{\\\\\\\"status\\\\\\\":\\\\\\\"completed\\\\\\\",\\\\\\\"eas_build_id\\\\\\\":\\\\\\\"${{ steps.eas.outputs.build_id }}\\\\\\\"}\\\"\\n\\n      - name: Update Build Status - Failed\\n        if: failure()\\n        env:\\n          GITHUB_RUN_ID: ${{ github.run_id }}\\n        run: |\\n          if [ -z \\\"$SUPABASE_URL\\\" ] || [ -z \\\"$SUPABASE_SERVICE_ROLE_KEY\\\" ]; then\\n            echo 'Supabase ENV Variablen fehlen, überspringe DB-Update.'; exit 0;\\n          fi\\n\\n          cat > body.json <<JSON\\n          {\\n            \\\"status\\\": \\\"error\\\",\\n            \\\"github_run_id\\\": \\\"$GITHUB_RUN_ID\\\"\\n          }\\n          JSON\\n\\n          curl -sS -X PATCH \\\"$SUPABASE_URL/rest/v1/build_jobs?id=eq.${JOB_ID}\\\" \\\\\\n            -H \\\"apikey: $SUPABASE_SERVICE_ROLE_KEY\\\" \\\\\\n            -H \\\"Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY\\\" \\\\\\n            -H \\\"Content-Type: application/json\\\" \\\\\\n            -d @body.json\\n\"
  },
  {
    "path": ".gitignore",
    "content": "node_modules/\\n.expo/\\n.expo-shared/\\nweb-build/\\ndist/\\n.env\\n.env.local\\n*.jks\\n*.p8\\n*.p12\\n*.key\\n*.mobileprovision\\n*.orig.*\\n"
  },
  {
    "path": "README.md",
    "content": "# K1w1 – Standard Build Files\\n\\nDieses Template liefert nur die Dateien, die du für den automatischen GitHub-Workflow und EAS Build brauchst.\\n\\n## Voraussetzungen (GitHub Secrets)\\n- EXPO_TOKEN\\n- EXPO_PROJECT_ID\\n- SUPABASE_URL\\n- SUPABASE_SERVICE_ROLE_KEY\\n\\n## Hinweise\\n- **Keine Icons/Splash** referenziert, damit Builds auch ohne Assets laufen.\\n- Deine App kann später Icons erzeugen und `app.json` erweitern.\\n"
  }
]
